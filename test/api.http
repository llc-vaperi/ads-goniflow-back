@base = http://localhost:3001


###
get {{base}}/

###
get {{base}}/api/v1/test

###
get {{base}}/api/v1/users


# ==================== SUPABASE AUTH TEST ENDPOINTS ====================

### 1. Register a new user
POST {{base}}/api/v1/auth/signup
Content-Type: application/json

{
  "email": "test@gmail.com",
  "password": "strongPassword123"
}

### 2. Login to get Access Token (JWT)
# @name login
POST {{base}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "test@gmail.com",
  "password": "strongPassword123"
}

### Capture JWT Token from Login Response
@token = {{login.response.body.data.session.access_token}}


### 3. Get Current User Info (Authorized)
GET {{base}}/api/v1/auth/me
Authorization: Bearer {{token}}

### 4. Get Current User Info (Unauthorized - Should return 401)
GET {{base}}/api/v1/auth/me


### 5. Forgot Password (Request reset email)
POST {{base}}/api/v1/auth/forgot-password
Content-Type: application/json

{
  "email": "test1@gmail.com",
  "redirectTo": "http://localhost:3000/reset-password"
}

### 6. Reset Password (Requires Bearer token from email redirect)
POST {{base}}/api/v1/auth/reset-password
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "newPassword": "newStrongPassword456"
}


### 7. Logout
POST {{base}}/api/v1/auth/logout
Content-Type: application/json
